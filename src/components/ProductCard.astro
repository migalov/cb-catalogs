---
const {title, src, pages, price, href} = Astro.props;
---
<div class="cb-product-card">
    <a href={href}>
        <img src={src} />
        <img src="" />
        <div class="cb-product-card__info">
            <div class="cb-product-card__price">
                <span class="cb-product-card__price-value">{price}</span>
                <span class="cb-product-card__price-currency">₽</span>
            </div>
            <h3 class="cb-product-card__title">{title}</h3>
            <span class="cb-product-card__additional-description" set:html={pages} />
        </div>
    </a>
</div>

<style lang="scss">

    .cb-product-card {
        border-radius: .3rem;
        transition: var(--defaultAnimate);

        & img {
            width: 100%;
            object-fit: cover;
            min-height: 200px;
            aspect-ratio: 1/1;
            transition: ease .4s;

            &:nth-child(1) {
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
            }

            &:hover {
                &:nth-child(1) {
                    opacity: 0;
                }
            }
        }


        & a {
            position: relative;
            display: flex;
            flex-direction: column;
            color: inherit;
            text-decoration: none;
            height: 100%;
        }
        &:hover {
            //box-shadow: var(--shadow-default-hover);
        }
    }
    .cb-product-card__additional-description {
        // margin-top: auto;
        // font-size: .7rem;
        display: flex;
        flex-direction: column;
        gap: .54em;
        font-size: .8125rem;
        font-family: var(--font-title);
        color: #7a7a7a;
    }
    .cb-product-card__info {
        // flex: 1;
        // display: flex;
        // flex-wrap: wrap;
        // padding: 1rem 0;
        // justify-content: space-between;
        // font-size: .75rem;
        // row-gap: .5em;
    }
    .cb-product-card__title {
        font-family: var(--font-text);
        font-size: 0.825rem;
        font-weight: 400;
        // margin: 0;
        // width: 100%;
        // font-size: .75rem;
    }
    .cb-product-card__price {
        // margin-top: auto;
        // font-weight: 700;
        // color: var(--primaryColor)
    }
</style>